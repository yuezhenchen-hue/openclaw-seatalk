{
	"name": "openclaw-seatalk",
	"version": "0.3.3",
	"description": "OpenClaw SeaTalk channel plugin",
	"type": "module",
	"main": "./dist/index.js",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lf4096/openclaw-seatalk.git"
	},
	"homepage": "https://github.com/lf4096/openclaw-seatalk#readme",
	"bugs": "https://github.com/lf4096/openclaw-seatalk/issues",
	"keywords": [
		"openclaw",
		"seatalk",
		"chatbot",
		"channel-plugin"
	],
	"engines": {
		"node": ">=22.16.0"
	},
	"files": [
		"dist/**/*.js",
		"openclaw.plugin.json",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsup",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --fix .",
		"check": "biome check .",
		"check:fix": "biome check --fix .",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@sinclair/typebox": "0.34.48",
		"ws": "^8.18.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/ws": "^8.5.0",
		"openclaw": "latest",
		"tsup": "^8.3.0",
		"typescript": "^5.6.0"
	},
	"peerDependencies": {
		"openclaw": ">=2026.3.22"
	},
	"peerDependenciesMeta": {
		"openclaw": {
			"optional": true
		}
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome"
		]
	},
	"openclaw": {
		"extensions": [
			"./dist/index.js"
		],
		"setupEntry": "./dist/setup-entry.js",
		"channel": {
			"id": "seatalk",
			"label": "SeaTalk",
			"selectionLabel": "SeaTalk (plugin)",
			"blurb": "SeaTalk messaging integration",
			"order": 70,
			"quickstartAllowFrom": true
		},
		"install": {
			"npmSpec": "openclaw-seatalk",
			"defaultChoice": "npm"
		},
		"compat": {
			"pluginApi": ">=2026.3.22"
		},
		"build": {
			"openclawVersion": "2026.3.22",
			"pluginSdkVersion": "2026.3.22"
		},
		"release": {
			"publishToNpm": true,
			"publishToClawHub": true
		}
	}
}
